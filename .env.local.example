# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — required for register/login API
# Supabase Dashboard → Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional: access control
# REGISTRATION_OPEN=false          # hide register tab and block new sign-ups
# REGISTRATION_SECRET=your-secret  # require secret when creating a new family (optional)

# App admin — can open/close users & families at /dashboard/admin
# Use your login username (easiest) or Supabase user UUID
# APP_ADMIN_USERNAMES=your-parent-username
# APP_ADMIN_USER_IDS=uuid-from-supabase-users-table
